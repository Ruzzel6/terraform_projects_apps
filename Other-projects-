4) to create each log files:

terraform {
  required_providers {
    local = {
      source = "hashicorp/local"
      version = "~> 2.6"
    }
  }
}
 
variable "files" {
  default = ["app.log", "db.log", "nginx.log"]
}
 
resource "local_file" "logs" {
  for_each = toset(var.files) #for_each tells Terraform: "Run this block once for every item in the collection."
  filename = each.value
  content  = "Log file: ${each.value}"
  file_permission      = "0644"
  directory_permission = "0755"
}



$ cat outputs.tf
output "log_files" {
  value = {
    for filename, file in local_file.logs :
    filename => "File: ${file.filename}\nContent: ${file.content}"
  }
}
