5. Production-ready Terraform project builds a modular full-stack DevOps lab for reusable modules for networking/VPC, compute (EC2 with Docker), local testing (Docker + config gen), secured by workspaces (dev/staging/prod) and S3 backend. It deploys a custom Nginx app across envs with variables/outputs/null_resource for validation.

Zero manual steps post-init


modular_terraform_project/
├── main.tf
├── variables.tf
├── modules/
|--- backend.tf
│   ├── vpc/
│   │   └── main.tf
│   ├── ec2/
│   │   └── main.tf
│   └── nginx_app/
│       └── main.tf


✅ backend.tf

terraform {
  backend "s3" {
    bucket         = "moi-terraform-state-bucket"   # must already exist
    key            = "devops-lab/terraform.tfstate" # static key
    region         = "us-east-1"
    dynamodb_table = "terraform-locks"              # must already exist
    encrypt        = true
  }
}


🔷 ROOT: main.tf

terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}

locals {
  env = terraform.workspace
}

module "vpc" {
  source = "./modules/vpc"
  env    = local.env
}

module "ec2" {
  source        = "./modules/ec2"
  env           = local.env
  instance_type = var.instance_type
  subnet_id     = module.vpc.subnet_id
  sg_id         = module.vpc.sg_id
}

module "nginx_app" {
  source = "./modules/nginx_app"
  env    = local.env
  ec2_ip = module.ec2.public_ip
}

🔷 ROOT: variables.tf

variable "instance_type" {
  default = "t2.micro"
}

🌐 MODULE: modules/vpc/main.tf
variable "env" {}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "${var.env}-vpc"
  }
}

resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.0.1.0/24"
  map_public_ip_on_launch = true

  tags = {
    Name = "${var.env}-public-subnet"
  }
}

resource "aws_internet_gateway" "igw" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name = "${var.env}-igw"
  }
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.igw.id
  }

  tags = {
    Name = "${var.env}-public-rt"
  }
}

resource "aws_route_table_association" "public_assoc" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

resource "aws_security_group" "web" {
  vpc_id = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "${var.env}-sg"
  }
}

output "subnet_id" {
  value = aws_subnet.public.id
}

output "sg_id" {
  value = aws_security_group.web.id
}

🖥️ MODULE: modules/ec2/main.tf

variable "env" {}
variable "instance_type" {}
variable "subnet_id" {}
variable "sg_id" {}

resource "aws_instance" "web" {
  ami                         = "ami-091138d0f0d41ff90"
  instance_type               = var.instance_type
  subnet_id                   = var.subnet_id
  vpc_security_group_ids      = [var.sg_id]
  associate_public_ip_address = true

  user_data = <<-EOF
    #!/bin/bash
    apt-get update -y
    apt-get install -y docker.io

    systemctl start docker
    systemctl enable docker

    sleep 10

    docker run -d -p 80:80 --name nginx nginx

    sleep 15

    docker exec nginx bash -c 'echo "<h1>${var.env} - DevOps Lab</h1>" > /usr/share/nginx/html/index.html'
  EOF

  tags = {
    Name = "${var.env}-ec2"
  }
}

output "public_ip" {
  value = aws_instance.web.public_ip
}

🌐 MODULE: modules/nginx_app/main.tf

variable "env" {}
variable "ec2_ip" {}

resource "null_resource" "validate" {
  provisioner "local-exec" {
    interpreter = ["/bin/bash", "-c"]   
    command = <<EOT
      echo "Validating ${var.ec2_ip}"

      for i in {1..15}; do
        response=$(curl -s http://${var.ec2_ip})
        echo "$response"

        echo "$response" | grep "${var.env}" && exit 0

        echo "Retry $i..."
        sleep 5
      done

      echo "Validation failed"
      exit 1
    EOT
  }
}


🧱 Prerequisites

1. S3 Bucket
aws s3 mb s3://moi-terraform-state-bucket

2. DynamoDB Table
aws dynamodb create-table \
  --table-name terraform-locks \
  --attribute-definitions AttributeName=LockID,AttributeType=S \
  --key-schema AttributeName=LockID,KeyType=HASH \
  --billing-mode PAY_PER_REQUEST \
  --region us-east-1


##To apply only one module 
$ terraform apply -replace=module.nginx_app.null_resource.validate
